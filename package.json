    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "posthog-js": "^1.373.5",
    "posthog-node": "^5.34.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.11.0",
    "shadcn": "^4.1.0",
    "streamdown": "^2.5.0",
    "stripe": "^22.0.1",

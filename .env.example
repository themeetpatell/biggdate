# ─── Supabase (required) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_DB_URL=postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Optional fallback if you prefer a generic env name
DATABASE_URL=

# ─── AI Provider ───
# Options: gemini (default, free tier), openai, ollama-cloud, ollama (local)
AI_PROVIDER=gemini

# Gemini (default — free tier: 15 RPM, 1M tokens/day)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (paid)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1

# Ollama local (free, requires local Ollama server)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# Ollama Cloud
OLLAMA_CLOUD_HOST=https://ollama.com
OLLAMA_API_KEY=your_ollama_key_if_needed
OLLAMA_CLOUD_MODEL=gpt-oss:120b

# Gemini
AI_PROVIDER=gemini
GEMINI_API_KEY=AIzaSyCsqAibx_QqIIDlI4d1FiXFo0QzoawSM6c
GEMINI_MODEL=gemini-2.5-flash
PORT=8787

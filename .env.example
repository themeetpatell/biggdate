# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_URL=postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Admin
# Comma-separated Supabase user IDs.
ADMIN_USER_IDS=

# AI provider
# Options: gemini, openai, ollama-cloud, ollama
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b
OLLAMA_CLOUD_HOST=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_CLOUD_MODEL=gpt-oss:120b

# Billing mode
# "early_access" → coupon-code redemption via WhatsApp; Stripe checkout disabled.
# "stripe"       → real Stripe checkout (requires the keys below to be set).
# NEXT_PUBLIC_* mirror is needed because the UpgradeSheet branches client-side.
BILLING_MODE=early_access
NEXT_PUBLIC_BILLING_MODE=early_access
# Comma-separated list of valid early-access coupon codes for the Premium plan.
EARLY_ACCESS_CODES=themeetpatel
# Per-addon coupon codes. JSON object mapping coupon-string → addon-id slug.
# Valid addon ids: profile_boost, life_preview, life_preview_3, super_like,
# profile_review, spotlight, read_receipts, incognito.
# Example: {"BOOST_FREE":"profile_boost","INCOGNITO30":"incognito"}
ADDON_COUPON_CODES={}
# Operator WhatsApp number used in the "Don't have a code?" CTA.
NEXT_PUBLIC_EARLY_ACCESS_WHATSAPP=+919824341414

# Stripe (used only when BILLING_MODE=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_QUARTERLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_QUARTERLY=
NEXT_PUBLIC_STRIPE_PRICE_BOOST=
NEXT_PUBLIC_STRIPE_PRICE_LIFE_PREVIEW=
NEXT_PUBLIC_STRIPE_PRICE_LIFE_PREVIEW_3=
NEXT_PUBLIC_STRIPE_PRICE_SUPER_LIKE=
NEXT_PUBLIC_STRIPE_PRICE_READ_RECEIPTS=
NEXT_PUBLIC_STRIPE_PRICE_INCOGNITO=
NEXT_PUBLIC_STRIPE_PRICE_PROFILE_REVIEW=
NEXT_PUBLIC_STRIPE_PRICE_SPOTLIGHT=

# Email
RESEND_API_KEY=
RESEND_FROM=

# Rate limiting / Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Moderation
SIGHTENGINE_USER=
SIGHTENGINE_SECRET=

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# 64-char random string. Used to anonymize Pulse author handles per-thread.
# Generate: node -e "console.log(require(\047crypto\047).randomBytes(48).toString(\047base64url\047))"
# IMPORTANT: never rotate after launch — would break thread-handle continuity.
PULSE_ANON_SECRET=

# Internal API secret — required for server-to-server email notification calls.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=

# Web Push (VAPID) — required for push notifications.
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:push@biggdate.app

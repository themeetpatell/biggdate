# Copy to apps/mobile/.env and fill in. EXPO_PUBLIC_* values are inlined
# into the app bundle at build time — never put server secrets here.

# Supabase project (same project as the web app)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Backend base URL. Local dev: http://localhost:3000
# Device testing: use your machine's LAN IP, e.g. http://192.168.1.20:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
